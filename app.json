{
  "applicationTitle": "Staff Application",
  "description": "Please fill out all fields honestly and completely if you don't use ur real discord username or steam ID you will be auto rejected.",
  "fields": [
    {
      "id": "Postion",
      "label": "Postion",
      "type": "select",
      "required": true,
      "options": ["Discord Mod", "In-game Staff"]
    },
    {
      "id": "discord_name",
      "label": "What is your Discord username?",
      "type": "text",
      "required": true,
      "placeholder": "Enter your Discord username"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "required": true,
      "placeholder": "Enter your age"
    },
    {
      "id": "steam_id",
      "label": "What is your steam ID?",
      "type": "text",
      "required": true,
      "placeholder": "Enter your steam ID"
    },
    {
      "id": "experience",
      "label": "Do you have any prior staff experience in SCP SL or discord?(if not put N/A)",
      "type": "textarea",
      "required": true,
      "placeholder": "Describe your experience"
    },
    {
      "id": "why_join",
      "label": "Why do you want to join?",
      "type": "textarea",
      "required": true,
      "placeholder": "Explain why you want to join"
    },
    {
      "id": "availability",
      "label": "Availability",
      "type": "select",
      "required": true,
      "options": ["Weekdays", "Weekends", "Both"]
    }
  ],
  "submitButton": {
    "text": "Submit Application"
  }
}

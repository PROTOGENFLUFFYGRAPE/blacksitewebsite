{
  "applicationTitle": "Website Application",
  "description": "Please fill out all fields honestly and completely.",
  "fields": [
    {
      "id": "discord_name",
      "label": "What is your Discord name?",
      "type": "text",
      "required": true,
      "placeholder": "Enter your Discord name"
    },
    {
      "id": "age",
      "label": "Age",
      "type": "number",
      "required": true,
      "placeholder": "Enter your age"
    },
    {
      "id": "steam_id",
      "label": "What is your steam id?",
      "type": "text",
      "required": true,
      "placeholder": "Enter your steam id"
    },
    {
      "id": "experience",
      "label": "Do you have any prior staff experience in SCP SL? (if not put N/A)",
      "type": "textarea",
      "required": true,
      "placeholder": "Describe your experience"
    },
    {
      "id": "why_join",
      "label": "Why do you want to join?",
      "type": "textarea",
      "required": true,
      "placeholder": "Explain why you want to join"
    },
    {
      "id": "availability",
      "label": "Availability",
      "type": "select",
      "required": true,
      "options": [
        "Weekdays",
        "Weekends",
        "Both",
        "Occasionally"
      ]
    },
    {
      "id": "tos_agreement",
      "label": "I agree that all information provided is truthful.",
      "type": "checkbox",
      "required": true
    }
  ],
  "submitButton": {
    "text": "Submit Application"
  }
}
